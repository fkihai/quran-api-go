# Quran API Go - Production Environment
# ====================================

# Database
DB_PATH=./data/quran.db

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# CORS - Ganti dengan domain production kamu
ALLOWED_ORIGINS=https://quran-api.example.com,https://www.quran-api.example.com

# Application
APP_VERSION=1.0.0
LOG_LEVEL=info

# Optional: Untuk monitoring
# PPROF_ENABLED=true
