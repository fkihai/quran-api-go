# Quran API Go - Dokploy Environment Variables
# ===========================================

# Database - path absolute karena di container WORKDIR=/app
DB_PATH=/app/data/quran.db

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# CORS - Ganti dengan domain production kamu
ALLOWED_ORIGINS=https://app.ilmunara.com,https://ilmunara.com

# Application
APP_VERSION=1.0.0
LOG_LEVEL=info